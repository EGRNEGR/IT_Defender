{
  "manifest_version": 3,
  "name": "AI-Privacy Sentinel",
  "version": "1.4.0",
  "description": "Prevents accidental disclosure of PII and secrets in browser text inputs and LLM chat interfaces.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "icons": {
    "16": "icon-128.png",
    "32": "icon-128.png",
    "48": "icon-128.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon-128.png",
      "32": "icon-128.png",
      "48": "icon-128.png",
      "128": "icon-128.png"
    },
    "default_title": "AI-Privacy Sentinel",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "detector.js",
        "ui-manager.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
